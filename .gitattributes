# Normalizar saltos de línea a LF en el repositorio, checkout según OS
* text=auto eol=lf

# Forzar LF en archivos de código y config
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.properties text eol=lf

# Binarios — no tocar
*.jar binary
*.png binary
*.jpg binary
